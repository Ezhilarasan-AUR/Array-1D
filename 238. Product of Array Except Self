class Solution {
    public int[] productExceptSelf(int[] nums) {
       int n=nums.length;
       int[] pe=new int[n];
       int[]  se=new int[n];
       int[] a=new int[n];
       pe[0]=nums[0];
       for(int i=1;i<n;i++){
                pe[i]=pe[i-1]*nums[i];
       }
       se[n-1]=nums[n-1];
        for(int i=n-2;i>=0;i--){
            se[i]=se[i+1]*nums[i];
        }
        for(int i=0;i<n;i++){
            int l=(i==0)?1:pe[i-1];
            int r=(i==n-1)?1:se[i+1];
            a[i]=l*r;
        }
        return a;
    }
}
